# ============================================
# 開發環境變數範本
# 複製此檔案為 .env.dev 並填入實際值
# cp .env.example.dev .env.dev
# ============================================

ENVIRONMENT=development

DATABASE_HOST=postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=postgres

# Backend (Rails)
EXTERNAL_BACKEND_PORT=6789
RAILS_PORT=3001

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:6789
API_INTERNAL_URL=http://backend:3001
EXTERNAL_FRONTEND_PORT=5678
NEXT_JS_PORT=3000

# Cloudflare R2 儲存
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_ASSETS_DOMAIN=
