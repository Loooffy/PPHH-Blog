# ============================================
# 正式環境變數範本
# 複製此檔案為 .env.prod 並填入實際值
# cp .env.example.prod .env.prod
# ============================================

ENVIRONMENT=production

DATABASE_HOST=postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=pphh_blog_production

# Backend (Rails)
EXTERNAL_BACKEND_PORT=6789
RAILS_PORT=3001
RAILS_MAX_THREADS=5

# Rails 加密金鑰 (執行 bin/rails secret 取得)
RAILS_MASTER_KEY=

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
EXTERNAL_FRONTEND_PORT=5678
NEXT_JS_PORT=3000

# Cloudflare R2 儲存
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_ASSETS_DOMAIN=
